<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.mediamusicplayer.controller.MusicPlayerController">

    <left>
        <VBox spacing="10.0" prefWidth="220.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="15.0" right="10.0" bottom="15.0" left="10.0"/>
            </padding>

            <Button text="🎵 Gestione Tutte le Tracce" onAction="#onViewAllTracksClick" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-background-color: #e0e0e0;" />

            <Label text="LE TUE PLAYLIST" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
            <ListView fx:id="playlistListView" VBox.vgrow="ALWAYS" />

            <VBox spacing="8.0">
                <TextField fx:id="newPlaylistInput" promptText="Nome nuova playlist..." />

                <Button text="Crea Playlist" onAction="#onAddPlaylistClick" maxWidth="Infinity" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                <Button text="Rinomina Playlist" onAction="#onRenamePlaylistClick" maxWidth="Infinity" style="-fx-background-color: #FFC107; -fx-text-fill: black;" />
                <Button text="Elimina Playlist" onAction="#onDeletePlaylistClick" maxWidth="Infinity" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="15.0">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>

            <Label fx:id="currentPlaylistLabel" text="Gestione Tracce: Tutte le canzoni" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <TableView fx:id="trackTable" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="titleColumn" text="Titolo" prefWidth="100.0" />
                    <TableColumn fx:id="authorColumn" text="Autore" prefWidth="100.0" />
                    <TableColumn fx:id="lengthColumn" text="Durata" prefWidth="100.0" />
                    <TableColumn fx:id="genreColumn" text="Genere" prefWidth="100.0" />
                    <TableColumn fx:id="yearColumn" text="Anno" prefWidth="100.0" />
                </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="10.0">
                <TextField fx:id="titleInput" promptText="Titolo" prefWidth="120.0" />
                <TextField fx:id="authorInput" promptText="Autore" prefWidth="120.0" />
                <TextField fx:id="lengthInput" promptText="Durata (es. 3:45)" prefWidth="100.0" />
                <TextField fx:id="genreInput" promptText="Genere" prefWidth="100.0" />
                <TextField fx:id="yearInput" promptText="Anno" prefWidth="70.0" />

                <Button text="Crea" onAction="#onAddTrackClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                <Button text="Modifica" onAction="#onUpdateTrackClick" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                <Button text="Elimina" onAction="#onDeleteTrackClick" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
            </HBox>

            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10 0 0 0; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
                <Label text="Aggiungi traccia selezionata a:" />
                <ComboBox fx:id="playlistComboBox" promptText="Scegli Playlist..." prefWidth="150.0" />
                <Button text="Aggiungi a Playlist" onAction="#onAssignToPlaylistClick" style="-fx-background-color: #FF9800; -fx-text-fill: white;" />
            </HBox>

        </VBox>
    </center>
</BorderPane>