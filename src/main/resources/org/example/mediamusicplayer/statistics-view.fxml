<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.mediamusicplayer.controller.StatisticsController"
            prefWidth="900"
            prefHeight="600"
            style="-fx-background-color: #f4f4f4;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #263238;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="5"/>
            </padding>

            <Button text="←"
                    fx:id="backButton"
                    onAction="#onBackClick"
                    minWidth="55.0"
                    prefWidth="55.0"
                    prefHeight="32.0"
                    style="-fx-background-color: #263238; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-border-color: transparent; -fx-padding: 0;"/>

            <Label text="Statistiche"
                   maxWidth="Infinity"
                   alignment="CENTER"
                   HBox.hgrow="ALWAYS"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text=""
                   prefWidth="30.0"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="30" alignment="CENTER"
              style="-fx-background-color: #f4f4f4;">
            <padding>
                <Insets top="35" right="35" bottom="35" left="35"/>
            </padding>

            <VBox spacing="18"
                  prefWidth="390"
                  prefHeight="430"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 12, 0, 0, 3);">

                <Label text="🎵 Brani più ascoltati"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #263238;"/>

                <Label fx:id="emptyTracksLabel"
                       text="Nessun brano ascoltato abbastanza a lungo."
                       visible="false"
                       managed="false"
                       wrapText="true"
                       style="-fx-text-fill: #757575; -fx-font-style: italic;"/>

                <ListView fx:id="mostPlayedTracksListView"
                          prefHeight="330"
                          style="-fx-background-radius: 8; -fx-border-color: #dddddd; -fx-border-radius: 8;"/>
            </VBox>

            <VBox spacing="18"
                  prefWidth="390"
                  prefHeight="430"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 12, 0, 0, 3);">

                <Label text="💿 Playlist più ascoltate"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #263238;"/>

                <Label fx:id="emptyPlaylistsLabel"
                       text="Nessuna playlist ancora riprodotta."
                       visible="false"
                       managed="false"
                       wrapText="true"
                       style="-fx-text-fill: #757575; -fx-font-style: italic;"/>

                <ListView fx:id="mostPlayedPlaylistsListView"
                          prefHeight="330"
                          style="-fx-background-radius: 8; -fx-border-color: #dddddd; -fx-border-radius: 8;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>